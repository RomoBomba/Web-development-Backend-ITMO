<!DOCTYPE html>
<html lang="ru">
<head>
    <%- include('head', {
    title: typeof title !== 'undefined' ? title : 'MusicStore',
    metaKeywords: typeof metaKeywords !== 'undefined' ? metaKeywords : null,
    metaDescription: typeof metaDescription !== 'undefined' ? metaDescription : null,
    useSwiper: typeof useSwiper !== 'undefined' ? useSwiper : false
    }) %>

    <style>
    /* Мобильное меню - критические стили */
    @media (max-width: 768px) {
        .mobile-menu-btn {
            display: flex !important;
            flex-direction: column;
            justify-content: space-around;
            width: 36px;
            height: 32px;
            background: transparent !important;
            border: none !important;
            cursor: pointer;
            padding: 0;
            margin-left: 12px;
            z-index: 10000;
        }

        .mobile-menu-btn span {
            display: block;
            width: 100%;
            height: 3px;
            background: #fff !important;
            border-radius: 3px;
            transition: all 0.3s ease;
        }

        .mobile-menu-btn.active span:nth-child(1) {
            transform: rotate(45deg) translate(6px, 6px);
        }

        .mobile-menu-btn.active span:nth-child(2) {
            opacity: 0;
        }

        .mobile-menu-btn.active span:nth-child(3) {
            transform: rotate(-45deg) translate(6px, -6px);
        }

        .nav__list {
            display: none !important;
            position: absolute !important;
            top: 100% !important;
            left: 0 !important;
            right: 0 !important;
            background: #1a252f !important;
            z-index: 9999 !important;
            flex-direction: column !important;
            margin: 0 !important;
            padding: 0 !important;
            box-shadow: 0 4px 10px rgba(0,0,0,0.3) !important;
        }

        .nav__list.active {
            display: flex !important;
        }

        .nav__item {
            border-bottom: 1px solid rgba(255,255,255,0.1) !important;
        }

        .nav__link {
            display: block;
            padding: 16px 20px !important;
            color: #fff !important;
            text-decoration: none;
        }

        .nav__link:hover, .nav__link:active {
            background: #e74c3c !important;
        }
    }
    </style>
</head>
<body class="page">
<header class="header">
    <div class="container">
        <div class="header__wrapper">
            <div class="header__left">
                <h1 class="header__title">MusicStore</h1>
                <nav class="nav" id="main-nav">
                    <button class="mobile-menu-btn" id="menu-toggle" aria-label="Меню" type="button" onclick="this.classList.toggle('active'); document.getElementById('nav-list').classList.toggle('active');">
                        <span></span><span></span><span></span>
                    </button>
                    <ul class="nav__list" id="nav-list">
                        <%- include('menu', { currentPage: typeof currentPage !== 'undefined' ? currentPage : '' }) %>
                    </ul>
                </nav>
            </div>
            <div class="header__right">
                <%- include('session', {
                isAuthenticated: typeof isAuthenticated !== 'undefined' ? isAuthenticated : false
                }) %>
            </div>
        </div>
    </div>
</header>

<main class="main">