<div class="session-block">
    <% if (isAuthenticated) { %>
        <div class="user-info">
            <div class="user-avatar">
                <div class="avatar-placeholder">👤</div>
            </div>
            <div class="user-details">
                <span class="user-greeting">Привет, <strong><%= userName || 'Гость' %></strong>!</span>
                <% if (userRole === 'admin') { %>
                    <span class="user-badge">👑 Админ</span>
                <% } %>
                <div class="user-actions">
                    <a href="/profile" class="session-link">Профиль</a>
                    <span class="separator">|</span>
                    <a href="#" id="logoutBtn" class="session-link logout-link">Выйти</a>
                </div>
            </div>
        </div>
    <% } else { %>
        <div class="auth-buttons">
            <a href="/login" class="session-link login-link">
                <span class="icon">🔐</span>
                Войти
            </a>
            <a href="/register" class="session-link register-link">
                <span class="icon">📝</span>
                Регистрация
            </a>
        </div>
    <% } %>
</div>

<script>
    document.getElementById('logoutBtn')?.addEventListener('click', async (e) => {
        e.preventDefault();
        await fetch('/auth/signout', { method: 'POST', credentials: 'include' });
        window.location.href = '/';
    });
</script>