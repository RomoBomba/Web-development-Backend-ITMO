<%- include('../partials/header', {
title: typeof product !== 'undefined' && product ? `Редактировать: ${product.name}` : 'Товар не найден',
metaKeywords: 'редактировать товар, MusicStore',
metaDescription: typeof product !== 'undefined' && product ? `Редактирование товара ${product.name}` : 'Товар не найден',
currentPage: 'products',
cartCount: 0,
isAuthenticated: true,
useSwiper: false,
useInputMask: false,
pageScript: null
}) %>

<div class="container">
    <% if (typeof product === 'undefined' || !product) { %>
        <div class="error-message">
            <h1>Товар не найден</h1>
            <p>Запрошенный товар не существует или был удален.</p>
            <a href="/products" class="button button--primary">Вернуться к списку</a>
        </div>
    <% } else { %>
        <h1>Редактировать товар: <%= product.name %></h1>

        <form action="/products/<%= product.id %>?_method=PATCH" method="POST" class="form">
            <div class="form__group">
                <label for="name" class="form__label">Название товара *</label>
                <input type="text" id="name" name="name" value="<%= product.name %>" required class="form__input">
            </div>

            <div class="form__group">
                <label for="description" class="form__label">Описание</label>
                <textarea id="description" name="description" rows="5" class="form__input"><%= product.description || '' %></textarea>
            </div>

            <div class="form__row">
                <div class="form__group">
                    <label for="price" class="form__label">Цена (руб.) *</label>
                    <input type="number" id="price" name="price" step="0.01" value="<%= product.price %>" required class="form__input">
                </div>

                <div class="form__group">
                    <label for="categoryId" class="form__label">Категория *</label>
                    <select id="categoryId" name="categoryId" class="form__input">
                        <option value="">Выберите категорию</option>
                        <option value="1" <%= product.categoryId === 1 ? 'selected' : '' %>>🎸 Электрогитары</option>
                        <option value="2" <%= product.categoryId === 8 ? 'selected' : '' %>>🎵 Акустические гитары</option>
                        <option value="3" <%= product.categoryId === 3 ? 'selected' : '' %>>🎸 Бас-гитары</option>
                        <option value="4" <%= product.categoryId === 4 ? 'selected' : '' %>>🔧 Аксессуары</option>
                    </select>
                </div>
            </div>

            <div class="form__group">
                <label for="image" class="form__label">URL изображения</label>
                <input type="url" id="image" name="image" value="<%= product.image || '' %>" class="form__input">
            </div>

            <div class="form__actions">
                <button type="submit" class="button button--primary">💾 Сохранить изменения</button>
                <a href="/products/<%= product.id %>" class="button button--secondary">↩️ Отмена</a>
            </div>
        </form>
    <% } %>
</div>

<style>
    .error-message {
        text-align: center;
        padding: 3rem;
        background: #f8f9fa;
        border-radius: 8px;
        border: 2px dashed #dee2e6;
        margin: 2rem 0;
    }
    .form__row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1rem;
    }
    .form__actions {
        display: flex;
        gap: 1rem;
        margin-top: 2rem;
    }
</style>

<%- include('../partials/footer') %>