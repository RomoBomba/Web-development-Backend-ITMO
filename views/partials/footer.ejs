<script>
    async function refreshSessionInfo() {
        try {
            const response = await fetch('/auth/check', {
                credentials: 'include'
            });
            const data = await response.json();
            console.log('🔄 Session refresh:', data);

            if (data.exists) {
                window.__SESSION__ = data;
                const sessionBlock = document.querySelector('.session-block');
                if (sessionBlock && !sessionBlock.querySelector('.user-info')) {
                    console.log('🔄 Session exists but UI not updated, reloading...');
                }
            } else {
                console.log('🔄 No session');
            }
        } catch (e) {
            console.log('❌ Session check failed:', e);
        }
    }

    refreshSessionInfo();

    window.addEventListener('load', function () {
        setTimeout(() => {
            const perfEntries = performance.getEntriesByType('navigation');
            if (perfEntries.length > 0) {
                const clientTime = perfEntries[0].loadEventEnd - perfEntries[0].startTime;
                const clientTimeElement = document.getElementById('client-load-time');
                if (clientTimeElement) {
                    clientTimeElement.textContent = Math.round(clientTime) + ' мс';
                }
            } else {
                const clientTime = performance.timing.loadEventEnd - performance.timing.navigationStart;
                const clientTimeElement = document.getElementById('client-load-time');
                if (clientTimeElement) {
                    clientTimeElement.textContent = clientTime + ' мс';
                }
            }
        }, 0);
    });

    async function checkCacheStatus() {
        try {
            const response = await fetch('/api/products/popular');
            let cacheHeader = response.headers.get('X-Cache');

            if (!cacheHeader) {
                cacheHeader = response.headers.get('CF-Cache-Status');
            }

            const cacheElement = document.getElementById('cache-status');
            if (cacheElement && cacheHeader) {
                if (cacheHeader === 'HIT' || cacheHeader === 'HIT') {
                    cacheElement.textContent = '✅ Из кэша';
                    cacheElement.style.color = '#27ae60';
                } else {
                    cacheElement.textContent = '🔄 Из БД';
                    cacheElement.style.color = '#e67e22';
                }
            } else if (cacheElement) {
                cacheElement.textContent = '📊 Кэш не определён';
                cacheElement.style.color = '#95a5a6';
            }
        } catch (e) {
            console.log('Cache check not available:', e);
        }
    }

    setTimeout(checkCacheStatus, 500);
</script>
