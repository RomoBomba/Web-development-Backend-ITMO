<!DOCTYPE html>
<html lang="ru">
<head>
    <%- include('head') %>
</head>
<body class="page">
<header class="header">
    <div class="container">
        <div class="header__wrapper">
            <div class="header__left">
                <h1 class="header__title">MusicStore</h1>
                <nav class="nav">
                    <%- include('menu', { currentPage: currentPage }) %>
                </nav>
            </div>
            <div class="header__right">
                <%- include('session', { isAuthenticated: isAuthenticated }) %>
            </div>
        </div>
    </div>
</header>

<script>
    document.querySelector('.header').addEventListener('click', function(e) {
        if (e.target === this || e.target.classList.contains('header')) {
            this.classList.toggle('header--expanded');
        }
    });
</script>

<main class="main">