<%- include('../partials/header', {
title: 'Управление пользователями',
currentPage: 'users',
cartCount: 0,
isAuthenticated: true,
userRole: userRole,
userName: userName
}) %>

<div class="container">
    <div class="users-header">
        <h1>👥 Управление пользователями</h1>
        <p class="users-subtitle">Всего пользователей: <strong><%= users.length %></strong></p>
    </div>

    <div class="users-table-container">
        <table class="users-table">
            <thead>
            <tr>
                <th>ID</th>
                <th>Email</th>
                <th>Имя</th>
                <th>Роль</th>
                <th>Дата регистрации</th>
                <th>Действия</th>
            </tr>
            </thead>
            <tbody>
            <% if (users && users.length > 0) { %>
                <% users.forEach(user => { %>
                    <tr class="user-row <%= user.role === 'admin' ? 'admin-row' : '' %>">
                        <td class="user-id">#<%= user.id %></td>
                        <td class="user-email"><%= user.email %></td>
                        <td class="user-name"><%= user.name || '—' %></td>
                        <td class="user-role">
                            <% if (user.role === 'admin') { %>
                                <span class="role-badge admin">👑 Администратор</span>
                            <% } else { %>
                                <span class="role-badge user">👤 Пользователь</span>
                            <% } %>
                        </td>
                        <td class="user-date"><%= new Date(user.createdAt).toLocaleDateString('ru-RU') %></td>
                        <td class="user-actions">
                            <button class="btn-icon edit-role" data-id="<%= user.id %>" data-role="<%= user.role %>" title="Изменить роль">🔧</button>
                            <button class="btn-icon delete-user" data-id="<%= user.id %>" data-name="<%= user.name || user.email %>" title="Удалить">🗑️</button>
                        </td>
                    </tr>
                <% }) %>
            <% } else { %>
                <tr>
                    <td colspan="6" class="empty-table">Нет зарегистрированных пользователей</td>
                </tr>
            <% } %>
            </tbody>
        </table>
    </div>
</div>

<style>
    .users-header {
        margin-bottom: 2rem;
        text-align: center;
    }
    .users-header h1 {
        margin-bottom: 0.5rem;
        color: var(--primary-color);
    }
    .users-subtitle {
        color: var(--text-light);
        font-size: 1rem;
    }
    .users-table-container {
        overflow-x: auto;
        background: white;
        border-radius: 12px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.08);
    }
    .users-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 0.9rem;
    }
    .users-table thead th {
        background: var(--primary-color);
        color: white;
        padding: 1rem;
        text-align: left;
        font-weight: 600;
    }
    .users-table tbody td {
        padding: 0.75rem 1rem;
        border-bottom: 1px solid #eee;
        vertical-align: middle;
    }
    .user-row:hover {
        background: #f8f9fa;
    }
    .admin-row {
        background: #fff8f0;
    }
    .user-id {
        font-weight: 600;
        color: var(--primary-color);
    }
    .user-email {
        font-family: monospace;
    }
    .role-badge {
        display: inline-block;
        padding: 0.25rem 0.75rem;
        border-radius: 20px;
        font-size: 0.8rem;
        font-weight: 500;
    }
    .role-badge.admin {
        background: #e74c3c;
        color: white;
    }
    .role-badge.user {
        background: #3498db;
        color: white;
    }
    .btn-icon {
        background: none;
        border: none;
        font-size: 1.2rem;
        cursor: pointer;
        padding: 0.25rem 0.5rem;
        margin: 0 0.25rem;
        border-radius: 6px;
        transition: all 0.2s ease;
    }
    .btn-icon:hover {
        background: #f0f0f0;
        transform: scale(1.05);
    }
    .edit-role:hover {
        background: #fff3cd;
    }
    .delete-user:hover {
        background: #fee;
        color: #e74c3c;
    }
    .empty-table {
        text-align: center;
        padding: 3rem;
        color: var(--text-light);
    }
    @media (max-width: 768px) {
        .users-table {
            font-size: 0.8rem;
        }
        .users-table thead th,
        .users-table tbody td {
            padding: 0.5rem;
        }
        .role-badge {
            padding: 0.15rem 0.5rem;
            font-size: 0.7rem;
        }
    }
</style>

<script>
    document.querySelectorAll('.edit-role').forEach(btn => {
        btn.addEventListener('click', async () => {
            const userId = btn.dataset.id;
            const currentRole = btn.dataset.role;
            const newRole = currentRole === 'admin' ? 'user' : 'admin';

            if (confirm(`Изменить роль пользователя на "${newRole}"?`)) {
                try {
                    const response = await fetch(`/api/users/${userId}`, {
                        method: 'PATCH',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ role: newRole }),
                        credentials: 'include'
                    });

                    if (response.ok) {
                        window.location.reload();
                    } else {
                        alert('Ошибка при изменении роли');
                    }
                } catch (error) {
                    console.error('Error:', error);
                    alert('Ошибка при изменении роли');
                }
            }
        });
    });

    document.querySelectorAll('.delete-user').forEach(btn => {
        btn.addEventListener('click', async () => {
            const userId = btn.dataset.id;
            const userName = btn.dataset.name;

            if (confirm(`Удалить пользователя "${userName}"? Это действие нельзя отменить.`)) {
                try {
                    const response = await fetch(`/api/users/${userId}`, {
                        method: 'DELETE',
                        credentials: 'include'
                    });

                    if (response.ok) {
                        window.location.reload();
                    } else {
                        alert('Ошибка при удалении пользователя');
                    }
                } catch (error) {
                    console.error('Error:', error);
                    alert('Ошибка при удалении пользователя');
                }
            }
        });
    });
</script>

<%- include('../partials/footer') %>