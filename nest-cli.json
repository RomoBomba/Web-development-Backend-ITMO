{
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "assets": [
      {
        "include": "../views/**/*.ejs",
        "outDir": "./dist/views",
        "watchAssets": true
      },
      {
        "include": "../public/**/*",
        "outDir": "./dist/public",
        "watchAssets": true
      }
    ],
    "watchAssets": true
  }
}